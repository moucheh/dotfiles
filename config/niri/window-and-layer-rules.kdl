layer-rule {
  match namespace="^wallpaper$"
  place-within-backdrop true
}

layer-rule {
  match namespace="^waybar$"

  background-effect {
      blur true
      xray true
  }
}

layer-rule {
    match namespace="^launcher$"
    match namespace="^~nwggrid$"
    match namespace=r#"^lhp\.LavaLauncher$"#
    match namespace="^logout_dialog$"

    shadow {
        on
    }

    background-effect {
      blur true
      xray false
    }
}

layer-rule {
    match namespace="swaync"

    block-out-from "screen-capture"
}

layer-rule {
    match namespace="swayosd"

    background-effect {
        blur true
        xray false
    }
}

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^com\.obsproject\.Studio$"#

    block-out-from "screen-capture"
}

window-rule {
    match app-id=r#"^at\.yrlf\.wl_mirror$"#

    open-on-output "HDMI-A-1"
    open-fullscreen true
}

window-rule {
    match title=r#"^Picture in picture$"#

    open-floating true
    default-floating-position x=950 y=300 relative-to="bottom-left"
    default-column-width { fixed 900; }
    default-window-height { fixed 500; }
}

window-rule {
    match app-id=r#"^org\.kde\.kdeconnect\.(handler|daemon)$"#

    open-floating true
    default-floating-position x=20 y=20 relative-to="bottom-right"
}

window-rule {
  match title="^Solitaire$"

  open-maximized true
}

window-rule {
  match app-id="neovide"

  background-effect {
    blur true
    xray true
  }
}

window-rule {
  match app-id="^brave"

  draw-border-with-background false
  opacity 0.9
  background-effect {
      blur true
      xray true
  }
}

window-rule {
  match app-id=r#"^org\.gnome\.Nautilus$"#
  match app-id=r#"^org\.gnome\.Calculator$"#
  match app-id=r#"^org\.gnome\.Evince$"#
  match app-id="^xdg-desktop-portal-gtk$"
  match app-id=r#"^org\.pulseaudio\.pavucontrol$"#
  match app-id="^blueman-manager$"
  match app-id="^FreeTube$"

  draw-border-with-background false
  opacity 0.8
  open-floating false
  background-effect {
      blur true
      xray true
  }
}
