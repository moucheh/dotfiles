layout {
    gaps 8
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 3
        active-gradient from="#7fc8ff" to="#24ddd4"
        inactive-gradient from="#505050" to="#606060"
    }

    insert-hint {
        gradient from="#7fc8ff" to="#24ddd4"
    }

    background-color   "#00000050"
}
